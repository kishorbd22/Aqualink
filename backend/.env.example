PORT=5000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://aqualink:aqualink_secret@localhost:5432/aqualink
DATABASE_URL_TEST=postgresql://aqualink:aqualink_secret@localhost:5432/aqualink_test

# Cache / Queue (Redis)
REDIS_URL=redis://localhost:6379

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# JWT (Authentication)
JWT_SECRET=aqualink-dev-secret-change-in-production
JWT_EXPIRES_IN=7d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
RATE_LIMIT_TRUST_PROXY=true