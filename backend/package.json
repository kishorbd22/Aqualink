{
  "name": "aqualink-backend",
  "version": "1.0.0",
  "description": "Aqualink - Backend API service",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "dev:5001": "cross-env PORT=5001 nodemon src/app.js",
    "test": "jest --coverage --forceExit",
    "test:watch": "jest --watch --forceExit",
    "test:coverage": "jest --coverage --forceExit",
    "migrate": "node src/database/migrate.js up",
    "migrate:down": "node src/database/migrate.js down",
    "migrate:status": "node src/database/migrate.js status",
    "lint": "eslint ."
  },
  "keywords": [
    "aqualink",
    "api",
    "backend"
  ],
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "hpp": "^0.2.3",
    "joi": "^18.2.3",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.11.3",
    "sequelize": "^6.35.0",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "umzug": "^3.8.0"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFiles": ["./tests/setup.js"],
    "testTimeout": 30000,
    "watchPathIgnorePatterns": ["node_modules"],
    "modulePathIgnorePatterns": ["node_modules"],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/app.js",
      "!src/database/**",
      "!src/docs/**",
      "!src/jobs/**"
    ]
  }
}